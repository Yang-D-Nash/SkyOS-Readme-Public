{
  "name": "skyos-functions",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "node --check index.js",
    "lint": "node --check index.js",
    "test": "npm run test:node && npm run test:rules",
    "serve": "firebase emulators:start --only functions",
    "deploy": "firebase deploy --only functions",
    "test:rules": "./node_modules/.bin/firebase emulators:exec --project demo-skydown --only firestore,storage \"node --test tests/**/*.test.js\"",
    "test:node": "node --test tests/roles.sync.test.js tests/app-check.test.js tests/functions.security.test.js",
    "list-exports": "node ../scripts/list_skyos_cloud_function_exports.mjs",
    "seed:founder-briefing": "node scripts/seed-founder-briefing-demo-data.mjs"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^3.0.0",
    "@genkit-ai/firebase": "^1.33.0",
    "@genkit-ai/google-genai": "^1.33.0",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "genkit": "^1.33.0",
    "nodemailer": "^8.0.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^4.0.1",
    "firebase": "^11.5.0",
    "firebase-tools": "^15.15.0"
  }
}
