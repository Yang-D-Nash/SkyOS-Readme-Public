# SkyOS v1.0.0 environment template
# Copy values into your local shell, CI secret store, Firebase secrets, or keystore.properties.
# Never commit real secret values.

# Android release signing
SKYOS_UPLOAD_STORE_FILE=androidApp/release/skyos-upload.jks
SKYOS_UPLOAD_STORE_PASSWORD=replace-with-store-password
SKYOS_UPLOAD_KEY_ALIAS=skyos-upload
SKYOS_UPLOAD_KEY_PASSWORD=replace-with-key-password

# Firebase / local QA scripts
SKYOS_FIREBASE_PROJECT_ID=skydown-a6add
SKYOS_FIREBASE_FUNCTIONS_REGION=us-central1
SKYOS_FIREBASE_WEB_API_KEY=replace-with-firebase-web-api-key
SKYOS_OWNER_EMAIL=owner@example.com
SKYOS_OWNER_PASSWORD=replace-with-local-qa-owner-password
# Optional: public support inbox default (order mail, fallbacks); see functions/src/security/constants.js
# SKYOS_SUPPORT_EMAIL=support@example.com

# Cloud Functions runtime / Firebase secrets
SMTP_CONNECTION_URL=smtp://user:password@smtp.example.com:465
STRIPE_SECRET_KEY=replace-with-stripe-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-stripe-webhook-secret
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_replace_me
SHOPIFY_STORE_DOMAIN=your-shop.myshopify.com
MANUS_API_KEY=replace-with-manus-key
XAI_API_KEY=replace-with-xai-key
SKYOS_IOS_APP_BUNDLE_ID=com.skydown.ios

# Social analytics enrichment for the Agent.
# Keep real values in your secret store / Cloud Run runtime config, never in git.
SPOTIFY_CLIENT_ID=replace-with-spotify-client-id
SPOTIFY_CLIENT_SECRET=replace-with-spotify-client-secret
YOUTUBE_DATA_API_KEY=replace-with-youtube-data-api-key
META_GRAPH_API_VERSION=v25.0
META_IG_USER_ID=replace-with-connected-instagram-business-id
META_IG_USER_ACCESS_TOKEN=replace-with-meta-instagram-token
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=replace-with-connected-instagram-business-id
META_INSTAGRAM_ACCESS_TOKEN=replace-with-meta-instagram-token
META_FACEBOOK_PAGE_ID=replace-with-facebook-page-id
META_FACEBOOK_PAGE_ACCESS_TOKEN=replace-with-facebook-page-token
META_FACEBOOK_USER_ACCESS_TOKEN=replace-with-meta-user-token
META_GRAPH_ACCESS_TOKEN=replace-with-shared-meta-token
TIKTOK_CLIENT_KEY=replace-with-tiktok-client-key
TIKTOK_CLIENT_SECRET=replace-with-tiktok-client-secret
TIKTOK_REDIRECT_URI=https://us-central1-skydown-a6add.cloudfunctions.net/tiktokOAuthCallback
TIKTOK_OAUTH_SCOPES=user.info.profile,user.info.stats,video.list
TIKTOK_USER_ACCESS_TOKEN=replace-with-optional-tiktok-user-token
SOCIAL_LIVE_CACHE_TTL_MINUTES=60

# Global Owner Activepieces flow: adminConfig/ownerActivepiecesFlow.
# Optional user-owned Activepieces/n8n flows: adminConfig/automationN8n_<uid>.
# Required fields: provider, scope, isEnabled, baseURL, webhookPath.
SKYOS_WORKFLOW_SECRET=replace-with-strong-workflow-secret
AGENT_RUN_CALLBACK_SECRET=replace-with-strong-run-callback-secret
