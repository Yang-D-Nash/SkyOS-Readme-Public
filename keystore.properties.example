# Copy this file to keystore.properties and replace the placeholder values.
# The real keystore.properties file must stay local and must never be committed.

SKYDOWN_UPLOAD_STORE_FILE=androidApp/release/skydown-upload.jks
SKYDOWN_UPLOAD_STORE_PASSWORD=replace-with-store-password
SKYDOWN_UPLOAD_KEY_ALIAS=skydown-upload
SKYDOWN_UPLOAD_KEY_PASSWORD=replace-with-key-password
