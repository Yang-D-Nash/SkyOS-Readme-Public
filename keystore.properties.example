# Copy this file to keystore.properties and replace the placeholder values.
# The real keystore.properties file must stay local and must never be committed.

SKYOS_UPLOAD_STORE_FILE=androidApp/release/skyos-upload.jks
SKYOS_UPLOAD_STORE_PASSWORD=replace-with-store-password
SKYOS_UPLOAD_KEY_ALIAS=skyos-upload
SKYOS_UPLOAD_KEY_PASSWORD=replace-with-key-password

# Existing local setups may still use the legacy SKYDOWN_UPLOAD_* keys.
