rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function claimRole() {
      return signedIn()
        && request.auth.token.role is string
        && request.auth.token.role in ["owner", "admin", "subadmin", "user"]
          ? request.auth.token.role
          : "user";
    }

    function userDocRole() {
      return currentUserDocExists()
        && currentUserDoc().role is string
        && currentUserDoc().role in ["owner", "admin", "subadmin", "user"]
          ? currentUserDoc().role
          : (
            currentUserDocExists() && currentUserDoc().isAdmin == true
              ? "admin"
              : claimRole()
          );
    }

    function effectiveRole() {
      return signedIn()
        ? (isOwnerEmail() ? "owner" : userDocRole())
        : "user";
    }

    function isOwner() {
      return signedIn() && effectiveRole() == "owner";
    }

    function isOwnerEmail() {
      return signedIn()
        && request.auth.token.keys().hasAny(["email"])
        && request.auth.token.email is string
        && request.auth.token.email.lower() == "nash.lioncorna@gmail.com";
    }

    function isAdmin() {
      return signedIn() && effectiveRole() in ["owner", "admin"];
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function currentUserDocExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function canManageMusicCatalog() {
      return isOwner() || (
        effectiveRole() == "admin"
        && currentUserDocExists()
        && currentUserDoc().canManageMusicCatalog == true
      );
    }

    function canManageVideoCatalog() {
      return isOwner() || (
        effectiveRole() == "admin"
        && currentUserDocExists()
        && currentUserDoc().canManageVideoCatalog == true
      );
    }

    function canModerateProfiles() {
      return isOwner() || (
        effectiveRole() == "admin"
        && currentUserDocExists()
        && currentUserDoc().canModerateProfiles == true
      );
    }

    function runtimeConfigExists() {
      return exists(/databases/$(database)/documents/system/runtimeConfig);
    }

    function runtimeConfig() {
      return get(/databases/$(database)/documents/system/runtimeConfig).data;
    }

    function lockdownEnabled() {
      return runtimeConfigExists() && runtimeConfig().lockdown == true;
    }

    function userWritesEnabled() {
      return !runtimeConfigExists() || runtimeConfig().userWritesEnabled != false;
    }

    function registrationsEnabled() {
      return !runtimeConfigExists() || runtimeConfig().registrationsEnabled != false;
    }

    function uploadsEnabled() {
      return !runtimeConfigExists() || runtimeConfig().uploadsEnabled != false;
    }

    function regularUserWriteAllowed() {
      return !lockdownEnabled() && userWritesEnabled();
    }

    function registrationWriteAllowed() {
      return !lockdownEnabled() && registrationsEnabled();
    }

    function requiredString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function optionalString(value, max) {
      return value == null || (value is string && value.size() <= max);
    }

    function optionalShortUrl(value) {
      return value == null || (
        value is string
        && value.size() <= 2048
        && value.matches("^https://.+$")
      );
    }

    function optionalShortUrlOrBlank(value) {
      return value == null || (
        value is string
        && value.size() <= 2048
        && (
          value.size() == 0
          || value.matches("^https://.+$")
        )
      );
    }

    function optionalTimestamp(value) {
      return value == null || value is timestamp;
    }

    function optionalBoolean(value) {
      return value == null || value is bool;
    }

    function optionalMapString(data, field, max) {
      return !data.keys().hasAny([field]) || optionalString(data[field], max);
    }

    function optionalMapShortUrl(data, field) {
      return !data.keys().hasAny([field]) || optionalShortUrl(data[field]);
    }

    function optionalMapShortUrlOrBlank(data, field) {
      return !data.keys().hasAny([field]) || optionalShortUrlOrBlank(data[field]);
    }

    function optionalMapTimestamp(data, field) {
      return !data.keys().hasAny([field]) || optionalTimestamp(data[field]);
    }

    function optionalMapBoolean(data, field) {
      return !data.keys().hasAny([field]) || optionalBoolean(data[field]);
    }

    function ownAutomationConfigDocId() {
      return "automationN8n_" + request.auth.uid;
    }

    function ownAgentProfileDocId() {
      return "agentProfile_" + request.auth.uid;
    }

    function isOwnAutomationAdminConfig(documentId) {
      return signedIn() && documentId == ownAutomationConfigDocId();
    }

    function isOwnAgentProfileAdminConfig(documentId) {
      return signedIn() && documentId == ownAgentProfileDocId();
    }

    function validWorkflowAutomationUserPayload() {
      return request.resource.data.keys().hasOnly([
        "provider",
        "isEnabled",
        "sendsUserContext",
        "workflowName",
        "baseURL",
        "webhookPath",
        "authHeaderName",
        "authHeaderValue",
        "knowledgeContext",
        "updatedAt"
      ])
      && (
        !request.resource.data.keys().hasAny(["provider"])
        || request.resource.data.provider == "n8n"
      )
      && (
        !request.resource.data.keys().hasAny(["isEnabled"])
        || request.resource.data.isEnabled is bool
      )
      && (
        !request.resource.data.keys().hasAny(["sendsUserContext"])
        || request.resource.data.sendsUserContext is bool
      )
      && optionalMapString(request.resource.data, "workflowName", 120)
      && optionalMapShortUrlOrBlank(request.resource.data, "baseURL")
      && optionalMapString(request.resource.data, "webhookPath", 512)
      && optionalMapString(request.resource.data, "authHeaderName", 120)
      && optionalMapString(request.resource.data, "authHeaderValue", 600)
      && optionalMapString(request.resource.data, "knowledgeContext", 4000)
      && optionalMapTimestamp(request.resource.data, "updatedAt");
    }

    function validPersonalAgentProfilePayload() {
      return request.resource.data.keys().hasOnly([
        "isEnabled",
        "roleLabel",
        "skillProfile",
        "outputFormat",
        "guardrails",
        "knowledgeContext",
        "updatedAt"
      ])
      && (
        !request.resource.data.keys().hasAny(["isEnabled"])
        || request.resource.data.isEnabled is bool
      )
      && optionalMapString(request.resource.data, "roleLabel", 240)
      && optionalMapString(request.resource.data, "skillProfile", 12000)
      && optionalMapString(request.resource.data, "outputFormat", 4000)
      && optionalMapString(request.resource.data, "guardrails", 4000)
      && optionalMapString(request.resource.data, "knowledgeContext", 4000)
      && optionalMapTimestamp(request.resource.data, "updatedAt");
    }

    function validImageContentType(value) {
      return value in ["image/jpeg", "image/png", "image/webp"];
    }

    function validMediaProvider(value) {
      return value == null || (
        value is string
        && value in ["firebase_storage", "google_drive", "mega", "external_link"]
      );
    }

    function hasBeatSource(data) {
      return (data.downloadURL is string && data.downloadURL.size() > 0)
        || (data.externalURL is string && data.externalURL.size() > 0);
    }

    function hasVideoSource(data) {
      return (data.downloadURL is string && data.downloadURL.size() > 0)
        || (data.externalURL is string && data.externalURL.size() > 0)
        || (data.embedURL is string && data.embedURL.size() > 0);
    }

    function validBeatHubPayload() {
      return request.resource.data.keys().hasOnly([
        "title",
        "artistName",
        "email",
        "notes",
        "fileName",
        "mimeType",
        "downloadURL",
        "externalURL",
        "storagePath",
        "uploaderName",
        "uploaderEmail",
        "uploaderID",
        "isPublic",
        "createdAt",
        "sourceProvider",
        "sourceFileID"
      ])
      && requiredString(request.resource.data.title, 1, 120)
      && requiredString(request.resource.data.artistName, 1, 80)
      && requiredString(request.resource.data.email, 5, 160)
      && requiredString(request.resource.data.fileName, 1, 256)
      && requiredString(request.resource.data.mimeType, 3, 160)
      && optionalMapString(request.resource.data, "notes", 1000)
      && optionalMapShortUrlOrBlank(request.resource.data, "downloadURL")
      && optionalMapShortUrlOrBlank(request.resource.data, "externalURL")
      && optionalMapString(request.resource.data, "storagePath", 512)
      && requiredString(request.resource.data.uploaderName, 1, 80)
      && requiredString(request.resource.data.uploaderEmail, 5, 160)
      && optionalMapString(request.resource.data, "uploaderID", 128)
      && request.resource.data.isPublic is bool
      && request.resource.data.createdAt is timestamp
      && validMediaProvider(request.resource.data.sourceProvider)
      && optionalMapString(request.resource.data, "sourceFileID", 256)
      && hasBeatSource(request.resource.data);
    }

    function validVideoHubPayload() {
      return request.resource.data.keys().hasOnly([
        "title",
        "projectName",
        "email",
        "notes",
        "fileName",
        "mimeType",
        "downloadURL",
        "externalURL",
        "embedURL",
        "storagePath",
        "uploaderName",
        "uploaderEmail",
        "uploaderID",
        "isPublic",
        "isHomeFeatured",
        "createdAt",
        "sourceProvider",
        "sourceFileID"
      ])
      && requiredString(request.resource.data.title, 1, 120)
      && requiredString(request.resource.data.projectName, 1, 80)
      && requiredString(request.resource.data.email, 5, 160)
      && requiredString(request.resource.data.fileName, 1, 256)
      && requiredString(request.resource.data.mimeType, 3, 160)
      && optionalMapString(request.resource.data, "notes", 1000)
      && optionalMapShortUrlOrBlank(request.resource.data, "downloadURL")
      && optionalMapShortUrlOrBlank(request.resource.data, "externalURL")
      && optionalMapShortUrlOrBlank(request.resource.data, "embedURL")
      && optionalMapString(request.resource.data, "storagePath", 512)
      && requiredString(request.resource.data.uploaderName, 1, 80)
      && requiredString(request.resource.data.uploaderEmail, 5, 160)
      && optionalMapString(request.resource.data, "uploaderID", 128)
      && request.resource.data.isPublic is bool
      && request.resource.data.isHomeFeatured is bool
      && request.resource.data.createdAt is timestamp
      && validMediaProvider(request.resource.data.sourceProvider)
      && optionalMapString(request.resource.data, "sourceFileID", 256)
      && hasVideoSource(request.resource.data);
    }

    function validScreenHeadersPayload() {
      return request.resource.data.keys().hasOnly([
        "homeImageURL",
        "homeEyebrow",
        "homeTitle",
        "homeSubtitle",
        "homeDetail",
        "musicHubImageURL",
        "musicHubEyebrow",
        "musicHubTitle",
        "musicHubSubtitle",
        "musicHubDetail",
        "shopImageURL",
        "shopEyebrow",
        "shopTitle",
        "shopSubtitle",
        "shopDetail",
        "videoHubImageURL",
        "videoHubEyebrow",
        "videoHubTitle",
        "videoHubSubtitle",
        "videoHubDetail",
        "updatedAt"
      ])
      && optionalMapShortUrlOrBlank(request.resource.data, "homeImageURL")
      && optionalMapString(request.resource.data, "homeEyebrow", 40)
      && optionalMapString(request.resource.data, "homeTitle", 80)
      && optionalMapString(request.resource.data, "homeSubtitle", 160)
      && optionalMapString(request.resource.data, "homeDetail", 280)
      && optionalMapShortUrlOrBlank(request.resource.data, "musicHubImageURL")
      && optionalMapString(request.resource.data, "musicHubEyebrow", 40)
      && optionalMapString(request.resource.data, "musicHubTitle", 80)
      && optionalMapString(request.resource.data, "musicHubSubtitle", 160)
      && optionalMapString(request.resource.data, "musicHubDetail", 280)
      && optionalMapShortUrlOrBlank(request.resource.data, "shopImageURL")
      && optionalMapString(request.resource.data, "shopEyebrow", 40)
      && optionalMapString(request.resource.data, "shopTitle", 80)
      && optionalMapString(request.resource.data, "shopSubtitle", 160)
      && optionalMapString(request.resource.data, "shopDetail", 280)
      && optionalMapShortUrlOrBlank(request.resource.data, "videoHubImageURL")
      && optionalMapString(request.resource.data, "videoHubEyebrow", 40)
      && optionalMapString(request.resource.data, "videoHubTitle", 80)
      && optionalMapString(request.resource.data, "videoHubSubtitle", 160)
      && optionalMapString(request.resource.data, "videoHubDetail", 280)
      && request.resource.data.updatedAt is timestamp;
    }

    function validLegalContentPayload() {
      return request.resource.data.keys().hasOnly([
        "brandName",
        "operatorName",
        "rightsHolderName",
        "supportEmail",
        "lastUpdatedLabel",
        "imprintReference",
        "masterNumberMeaning",
        "brandManifesto",
        "symbolicNumericCode",
        "symbolicLeetCode",
        "symbolicCodeExplanation",
        "updatedAt"
      ])
      && optionalMapString(request.resource.data, "brandName", 120)
      && optionalMapString(request.resource.data, "operatorName", 160)
      && optionalMapString(request.resource.data, "rightsHolderName", 160)
      && optionalMapString(request.resource.data, "supportEmail", 160)
      && optionalMapString(request.resource.data, "lastUpdatedLabel", 64)
      && optionalMapString(request.resource.data, "imprintReference", 1200)
      && optionalMapString(request.resource.data, "masterNumberMeaning", 2400)
      && optionalMapString(request.resource.data, "brandManifesto", 6000)
      && optionalMapString(request.resource.data, "symbolicNumericCode", 160)
      && optionalMapString(request.resource.data, "symbolicLeetCode", 160)
      && optionalMapString(request.resource.data, "symbolicCodeExplanation", 4000)
      && request.resource.data.updatedAt is timestamp;
    }

    function validUserCreatePayload() {
      return request.resource.data.keys().hasOnly([
        "email",
        "username",
        "profileImageURL",
        "profileImagePath",
        "whatsApp",
        "profileTagline",
        "profileBio",
        "instagramHandle",
        "registrationDateEpochMillis",
        "isAdmin",
        "role",
        "quotaPlan",
        "aiAccessEnabled",
        "termsAcceptedAt",
        "privacyAcceptedAt",
        "termsVersion",
        "privacyVersion",
        "legalConsentSource",
        "aiConsentGiven",
        "aiConsentUpdatedAt",
        "aiConsentSource",
        "aiTextRequestsPerDay",
        "aiVisualRequestsPerDay",
        "aiAgentRequestsPerDay",
        "aiHistoryRetentionDays",
        "canManageMusicCatalog",
        "canManageVideoCatalog",
        "canModerateProfiles"
      ])
      && requiredString(request.resource.data.email, 5, 160)
      && requiredString(request.resource.data.username, 1, 32)
      && optionalMapShortUrl(request.resource.data, "profileImageURL")
      && optionalMapString(request.resource.data, "profileImagePath", 256)
      && optionalMapString(request.resource.data, "whatsApp", 40)
      && optionalMapString(request.resource.data, "profileTagline", 60)
      && optionalMapString(request.resource.data, "profileBio", 240)
      && optionalMapString(request.resource.data, "instagramHandle", 40)
      && request.resource.data.registrationDateEpochMillis is int
      && request.resource.data.isAdmin == false
      && request.resource.data.role == "user"
      && request.resource.data.quotaPlan == "free"
      && request.resource.data.aiAccessEnabled is bool
      && request.resource.data.termsAcceptedAt is timestamp
      && request.resource.data.privacyAcceptedAt is timestamp
      && requiredString(request.resource.data.termsVersion, 1, 64)
      && requiredString(request.resource.data.privacyVersion, 1, 64)
      && requiredString(request.resource.data.legalConsentSource, 1, 64)
      && request.resource.data.aiConsentGiven is bool
      && request.resource.data.aiAccessEnabled == request.resource.data.aiConsentGiven
      && request.resource.data.aiConsentUpdatedAt is timestamp
      && requiredString(request.resource.data.aiConsentSource, 1, 64)
      && request.resource.data.aiTextRequestsPerDay == 30
      && request.resource.data.aiVisualRequestsPerDay == 4
      && request.resource.data.aiAgentRequestsPerDay == 18
      && request.resource.data.aiHistoryRetentionDays == 3
      && request.resource.data.canManageMusicCatalog == false
      && request.resource.data.canManageVideoCatalog == false
      && request.resource.data.canModerateProfiles == false;
    }

    function validOwnUserUpdatePayload() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        "username",
        "profileImageURL",
        "profileImagePath",
        "whatsApp",
        "profileTagline",
        "profileBio",
        "instagramHandle",
        "termsAcceptedAt",
        "privacyAcceptedAt",
        "termsVersion",
        "privacyVersion",
        "legalConsentSource",
        "aiAccessEnabled",
        "aiConsentGiven",
        "aiConsentUpdatedAt",
        "aiConsentSource"
      ])
      && request.resource.data.email == resource.data.email
      && request.resource.data.registrationDateEpochMillis == resource.data.registrationDateEpochMillis
      && request.resource.data.isAdmin == resource.data.isAdmin
      && request.resource.data.role == resource.data.role
      && request.resource.data.quotaPlan == resource.data.quotaPlan
      && request.resource.data.aiTextRequestsPerDay == resource.data.aiTextRequestsPerDay
      && request.resource.data.aiVisualRequestsPerDay == resource.data.aiVisualRequestsPerDay
      && request.resource.data.aiAgentRequestsPerDay == resource.data.aiAgentRequestsPerDay
      && request.resource.data.aiHistoryRetentionDays == resource.data.aiHistoryRetentionDays
      && request.resource.data.canManageMusicCatalog == resource.data.canManageMusicCatalog
      && request.resource.data.canManageVideoCatalog == resource.data.canManageVideoCatalog
      && request.resource.data.canModerateProfiles == resource.data.canModerateProfiles
      && requiredString(request.resource.data.username, 1, 32)
      && optionalMapShortUrl(request.resource.data, "profileImageURL")
      && optionalMapString(request.resource.data, "profileImagePath", 256)
      && optionalMapString(request.resource.data, "whatsApp", 40)
      && optionalMapString(request.resource.data, "profileTagline", 60)
      && optionalMapString(request.resource.data, "profileBio", 240)
      && optionalMapString(request.resource.data, "instagramHandle", 40)
      && optionalMapTimestamp(request.resource.data, "termsAcceptedAt")
      && optionalMapTimestamp(request.resource.data, "privacyAcceptedAt")
      && optionalMapString(request.resource.data, "termsVersion", 64)
      && optionalMapString(request.resource.data, "privacyVersion", 64)
      && optionalMapString(request.resource.data, "legalConsentSource", 64)
      && request.resource.data.aiAccessEnabled is bool
      && request.resource.data.aiConsentGiven is bool
      && request.resource.data.aiAccessEnabled == request.resource.data.aiConsentGiven
      && request.resource.data.aiConsentUpdatedAt is timestamp
      && optionalMapString(request.resource.data, "aiConsentSource", 64);
    }

    function validOwnerBootstrapPayload() {
      return request.resource.data.keys().hasOnly([
        "email",
        "username",
        "profileImageURL",
        "profileImagePath",
        "whatsApp",
        "profileTagline",
        "profileBio",
        "instagramHandle",
        "registrationDateEpochMillis",
        "isAdmin",
        "role",
        "quotaPlan",
        "aiAccessEnabled",
        "termsAcceptedAt",
        "privacyAcceptedAt",
        "termsVersion",
        "privacyVersion",
        "legalConsentSource",
        "aiConsentGiven",
        "aiConsentUpdatedAt",
        "aiConsentSource",
        "aiTextRequestsPerDay",
        "aiVisualRequestsPerDay",
        "aiAgentRequestsPerDay",
        "aiHistoryRetentionDays",
        "canManageMusicCatalog",
        "canManageVideoCatalog",
        "canModerateProfiles"
      ])
      && requiredString(request.resource.data.email, 5, 160)
      && requiredString(request.resource.data.username, 1, 32)
      && optionalMapShortUrl(request.resource.data, "profileImageURL")
      && optionalMapString(request.resource.data, "profileImagePath", 256)
      && optionalMapString(request.resource.data, "whatsApp", 40)
      && optionalMapString(request.resource.data, "profileTagline", 60)
      && optionalMapString(request.resource.data, "profileBio", 240)
      && optionalMapString(request.resource.data, "instagramHandle", 40)
      && request.resource.data.registrationDateEpochMillis is int
      && request.resource.data.isAdmin == true
      && request.resource.data.role == "owner"
      && request.resource.data.quotaPlan == "owner_unlimited"
      && request.resource.data.aiAccessEnabled == true
      && request.resource.data.termsAcceptedAt is timestamp
      && request.resource.data.privacyAcceptedAt is timestamp
      && requiredString(request.resource.data.termsVersion, 1, 64)
      && requiredString(request.resource.data.privacyVersion, 1, 64)
      && requiredString(request.resource.data.legalConsentSource, 1, 64)
      && request.resource.data.aiConsentGiven == true
      && request.resource.data.aiConsentUpdatedAt is timestamp
      && requiredString(request.resource.data.aiConsentSource, 1, 64)
      && request.resource.data.aiTextRequestsPerDay is int
      && request.resource.data.aiVisualRequestsPerDay is int
      && request.resource.data.aiAgentRequestsPerDay is int
      && request.resource.data.aiHistoryRetentionDays == 30
      && request.resource.data.canManageMusicCatalog == true
      && request.resource.data.canManageVideoCatalog == true
      && request.resource.data.canModerateProfiles == true;
    }

    function validStaffUserUpdatePayload() {
      return request.resource.data.keys().hasOnly([
        "email",
        "username",
        "profileImageURL",
        "profileImagePath",
        "whatsApp",
        "profileTagline",
        "profileBio",
        "instagramHandle",
        "registrationDateEpochMillis",
        "isAdmin",
        "role",
        "quotaPlan",
        "aiAccessEnabled",
        "termsAcceptedAt",
        "privacyAcceptedAt",
        "termsVersion",
        "privacyVersion",
        "legalConsentSource",
        "aiConsentGiven",
        "aiConsentUpdatedAt",
        "aiConsentSource",
        "aiTextRequestsPerDay",
        "aiVisualRequestsPerDay",
        "aiAgentRequestsPerDay",
        "aiHistoryRetentionDays",
        "canManageMusicCatalog",
        "canManageVideoCatalog",
        "canModerateProfiles",
        "updatedAt",
        "claimsSyncedAt",
        "claimsUpdatedByUid",
        "claimsUpdatedByEmail"
      ])
      && requiredString(request.resource.data.email, 5, 160)
      && requiredString(request.resource.data.username, 1, 32)
      && optionalMapShortUrl(request.resource.data, "profileImageURL")
      && optionalMapString(request.resource.data, "profileImagePath", 256)
      && optionalMapString(request.resource.data, "whatsApp", 40)
      && optionalMapString(request.resource.data, "profileTagline", 60)
      && optionalMapString(request.resource.data, "profileBio", 240)
      && optionalMapString(request.resource.data, "instagramHandle", 40)
      && request.resource.data.registrationDateEpochMillis is int
      && request.resource.data.role in ["owner", "admin", "subadmin", "user"]
      && request.resource.data.quotaPlan in [
        "owner_unlimited",
        "internal_team",
        "free",
        "creator",
        "studio"
      ]
      && request.resource.data.isAdmin is bool
      && request.resource.data.aiAccessEnabled is bool
      && request.resource.data.aiTextRequestsPerDay is int
      && request.resource.data.aiVisualRequestsPerDay is int
      && request.resource.data.aiAgentRequestsPerDay is int
      && request.resource.data.aiHistoryRetentionDays in [1, 3, 7, 30]
      && optionalMapTimestamp(request.resource.data, "termsAcceptedAt")
      && optionalMapTimestamp(request.resource.data, "privacyAcceptedAt")
      && optionalMapString(request.resource.data, "termsVersion", 64)
      && optionalMapString(request.resource.data, "privacyVersion", 64)
      && optionalMapString(request.resource.data, "legalConsentSource", 64)
      && optionalMapBoolean(request.resource.data, "aiConsentGiven")
      && optionalMapTimestamp(request.resource.data, "aiConsentUpdatedAt")
      && optionalMapString(request.resource.data, "aiConsentSource", 64)
      && optionalMapTimestamp(request.resource.data, "updatedAt")
      && (
        !request.resource.data.keys().hasAny(["aiConsentGiven"])
        || request.resource.data.aiConsentGiven == request.resource.data.aiAccessEnabled
      )
      && request.resource.data.canManageMusicCatalog is bool
      && request.resource.data.canManageVideoCatalog is bool
      && request.resource.data.canModerateProfiles is bool;
    }

    function validUserProfilePayload(uid) {
      return request.resource.data.keys().hasOnly([
        "ownerUid",
        "username",
        "profileImageURL",
        "profileImagePath",
        "profileTagline",
        "profileBio",
        "instagramHandle",
        "whatsApp",
        "createdAt",
        "updatedAt"
      ])
      && request.resource.data.ownerUid == uid
      && requiredString(request.resource.data.username, 1, 32)
      && optionalMapShortUrl(request.resource.data, "profileImageURL")
      && optionalMapString(request.resource.data, "profileImagePath", 256)
      && optionalMapString(request.resource.data, "profileTagline", 60)
      && optionalMapString(request.resource.data, "profileBio", 240)
      && optionalMapString(request.resource.data, "instagramHandle", 40)
      && optionalMapString(request.resource.data, "whatsApp", 40)
      && request.resource.data.createdAt is timestamp
      && request.resource.data.updatedAt is timestamp;
    }

    function validGalleryMetaPayload(uid) {
      return request.resource.data.keys().hasOnly([
        "ownerUid",
        "type",
        "title",
        "caption",
        "mediaURL",
        "thumbnailURL",
        "storagePath",
        "contentType",
        "createdAt",
        "updatedAt"
      ])
      && request.resource.data.ownerUid == uid
      && request.resource.data.type == "image"
      && requiredString(request.resource.data.title, 1, 60)
      && optionalMapString(request.resource.data, "caption", 240)
      && optionalMapShortUrl(request.resource.data, "mediaURL")
      && optionalMapShortUrl(request.resource.data, "thumbnailURL")
      && requiredString(request.resource.data.storagePath, 12, 256)
      && request.resource.data.storagePath.matches("^users/" + uid + "/gallery/[A-Za-z0-9_-]+\\.(jpg|jpeg|png|webp)$")
      && validImageContentType(request.resource.data.contentType)
      && request.resource.data.createdAt is timestamp
      && request.resource.data.updatedAt is timestamp;
    }

    function validArtistPagePayload(artistId) {
      return request.resource.data.keys().hasOnly([
        "slug",
        "brand",
        "artistName",
        "tagline",
        "bio",
        "profileImageURL",
        "heroImageURL",
        "instagramURL",
        "spotifyURL",
        "youtubeURL",
        "editorUids",
        "createdAt",
        "updatedAt"
      ])
      && request.resource.data.slug is string
      && request.resource.data.slug.matches("^[a-z0-9-]{1,80}$")
      && request.resource.data.brand in ["zweizwei", "skydown", "nicma"]
      && request.resource.data.brand + "-" + request.resource.data.slug == artistId
      && requiredString(request.resource.data.artistName, 1, 64)
      && optionalMapString(request.resource.data, "tagline", 80)
      && optionalMapString(request.resource.data, "bio", 600)
      && optionalMapShortUrl(request.resource.data, "profileImageURL")
      && optionalMapShortUrl(request.resource.data, "heroImageURL")
      && optionalMapShortUrl(request.resource.data, "instagramURL")
      && optionalMapShortUrl(request.resource.data, "spotifyURL")
      && optionalMapShortUrl(request.resource.data, "youtubeURL")
      && request.resource.data.editorUids is list
      && request.resource.data.editorUids.size() <= 12
      && request.resource.data.createdAt is timestamp
      && request.resource.data.updatedAt is timestamp;
    }

    match /system/runtimeConfig {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /uploadSlots/{slotId} {
      allow read, write: if false;
    }

    match /uploadUsage/{uid} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow create: if isSelf(uid)
        && registrationWriteAllowed()
        && (validUserCreatePayload() || (isOwnerEmail() && validOwnerBootstrapPayload()));

      allow read: if isSelf(uid) || isAdmin();

      allow update: if (
        isSelf(uid)
        && regularUserWriteAllowed()
        && validOwnUserUpdatePayload()
      ) || (
        isOwner()
        && validStaffUserUpdatePayload()
      );

      allow delete: if isSelf(uid) || isOwner();
    }

    match /users/{uid}/texts/{textId} {
      allow read: if isSelf(uid) || isOwner();
      allow create, update, delete: if (isSelf(uid) && regularUserWriteAllowed()) || isOwner();
    }

    match /users/{uid}/aiUsage/{usageId} {
      allow read: if isSelf(uid) || isOwner();
      allow create, update, delete: if false;
    }

    match /userProfiles/{uid} {
      allow create: if isSelf(uid)
        && regularUserWriteAllowed()
        && validUserProfilePayload(uid);

      allow read: if isSelf(uid) || canModerateProfiles();

      allow update: if (
        isSelf(uid)
        && regularUserWriteAllowed()
        && validUserProfilePayload(uid)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
      ) || (
        isOwner()
        && validUserProfilePayload(uid)
      );

      allow delete: if isSelf(uid) || isOwner();
    }

    match /galleryMeta/{uid}/items/{imageId} {
      allow create: if isSelf(uid)
        && regularUserWriteAllowed()
        && uploadsEnabled()
        && validGalleryMetaPayload(uid);

      allow read: if isSelf(uid) || canModerateProfiles();

      allow update: if (
        isSelf(uid)
        && regularUserWriteAllowed()
        && validGalleryMetaPayload(uid)
        && request.resource.data.ownerUid == resource.data.ownerUid
        && request.resource.data.createdAt == resource.data.createdAt
      );

      allow delete: if (isSelf(uid) && regularUserWriteAllowed()) || canModerateProfiles();
    }

    match /artistPages/{artistId} {
      allow read: if true;

      allow create: if isOwner()
        && validArtistPagePayload(artistId);

      allow update: if (
        isOwner()
        && validArtistPagePayload(artistId)
      ) || (
        signedIn()
        && resource.data.editorUids is list
        && resource.data.editorUids.hasAny([request.auth.uid])
        && validArtistPagePayload(artistId)
        && request.resource.data.slug == resource.data.slug
        && request.resource.data.brand == resource.data.brand
        && request.resource.data.artistName == resource.data.artistName
        && request.resource.data.editorUids == resource.data.editorUids
        && request.resource.data.createdAt == resource.data.createdAt
      );

      allow delete: if isOwner();
    }

    match /admin/{docId} {
      allow read, create, update, delete: if isOwner();
    }

    match /merchandise/{itemId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /orders/{orderId} {
      allow create: if false;
      allow read, update, delete: if isOwner();
    }

    match /appConfig/{documentId} {
      allow read: if documentId in [
        "merchandiseStore",
        "paymentMethods",
        "commerceSettings",
        "shopifyMerch",
        "screenHeaders",
        "legalContent"
      ];

      allow create, update, delete: if isOwner()
        && (
          (documentId == "screenHeaders" && validScreenHeadersPayload())
          || (documentId == "legalContent" && validLegalContentPayload())
          || (documentId != "screenHeaders" && documentId != "legalContent")
        );
    }

    match /adminConfig/{documentId} {
      allow read: if isOwner()
        || isOwnAutomationAdminConfig(documentId)
        || isOwnAgentProfileAdminConfig(documentId);

      allow create, update: if isOwner() || (
        regularUserWriteAllowed()
        && (
          (isOwnAutomationAdminConfig(documentId) && validWorkflowAutomationUserPayload())
          || (isOwnAgentProfileAdminConfig(documentId) && validPersonalAgentProfilePayload())
        )
      );

      allow delete: if isOwner() || (
        regularUserWriteAllowed()
        && (
          isOwnAutomationAdminConfig(documentId)
          || isOwnAgentProfileAdminConfig(documentId)
        )
      );
    }

    match /nicmaBeatHub/{beatId} {
      allow read: if canManageMusicCatalog() || resource.data.isPublic == true;
      allow create, update: if canManageMusicCatalog()
        && validBeatHubPayload();
      allow delete: if canManageMusicCatalog();
    }

    match /videographyHub/{videoId} {
      allow read: if canManageVideoCatalog() || resource.data.isPublic == true;
      allow create, update: if canManageVideoCatalog()
        && validVideoHubPayload();
      allow delete: if canManageVideoCatalog();
    }

    match /videographyHubMeta/{documentId} {
      allow read: if documentId == "publicConfig";
      allow create, update, delete: if canManageVideoCatalog() && documentId == "publicConfig";
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
