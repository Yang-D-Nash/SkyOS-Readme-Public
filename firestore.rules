rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{userId} {
      allow create: if isOwner(userId)
        && request.resource.data.isAdmin == false;

      allow read: if isOwner(userId) || isAdmin();

      allow update: if isAdmin() || (
        isOwner(userId)
        && request.resource.data.isAdmin == resource.data.isAdmin
      );

      allow delete: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/texts/{textId} {
      allow read, write: if isOwner(userId);
    }

    match /merchandise/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if signedIn()
        && request.resource.data.userEmail is string
        && request.resource.data.userEmail.size() > 0
        && request.resource.data.isCompleted == false;

      allow read, update, delete: if isAdmin();
    }

    match /nicmaBeatHub/{beatId} {
      allow read: if isAdmin() || resource.data.isPublic == true;
      allow create, update, delete: if isAdmin();
    }

    match /videographyHub/{videoId} {
      allow read: if isAdmin() || resource.data.isPublic == true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
